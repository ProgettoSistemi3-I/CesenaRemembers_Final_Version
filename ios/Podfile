# Piattaforma minima supportata
platform :ios, '13.0'

# Importante: Carica l'helper di Flutter
# Questo file viene generato da Flutter durante la build su Mac/Codemagic
flutter_install_display_name_ruby = File.join('..', '..', 'flutter', 'packages', 'flutter_tools', 'bin', 'xcode_backend.sh')

# Carica le configurazioni di Flutter
load File.join(File.dirname(File.realpath(__FILE__)), '.symlinks', 'plugins', 'flutter_export_environment.rb') if File.exist?(File.join(File.dirname(File.realpath(__FILE__)), '.symlinks', 'plugins', 'flutter_export_environment.rb'))

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Questa riga dice a CocoaPods di installare i plugin di Flutter
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Risolve problemi comuni di compatibilità con le architetture
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end